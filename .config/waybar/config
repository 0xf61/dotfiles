{
  "layer": "top",
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "network"
  ],
  "hyprland/workspaces": {
    "format": "{icon}: {name}",
    "tooltip": false,
    "all-outputs": false,
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΝ"
    }
  },
  "clock": {
    "format": "<span color='#b4befe'>ΎΑΩ </span>{:%H:%M}"
  },
  "tray": {
    "icon-size": 16,
    "spacing": 10
  },
  "backlight": {
    "device": "intel_backlight",
    "format": "<span color='#b4befe'>{icon}</span> {percent}%",
    "format-icons": [
      "ΌΟΞ",
      "ΌΠΥ",
      "ΌΠΣ",
      "ΌΠΠ",
      "ΌΠΟ",
      "ΌΠΞ",
      "ΌΠΛ",
      "ΌΠΙ",
      "ΌΟδ"
    ]
  },
  "pulseaudio": {
    "format": "<span color='#b4befe'>{icon}</span> {volume}%",
    "format-muted": "ΎΑο",
    "tooltip": false,
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": [
        "ΎΑο",
        "ΎΑπ",
        "≤░Χ╛",
        "≤░Χ╛",
        "≤░Χ╛",
        "ΎΑρ",
        "ΎΑρ",
        "ΎΑρ"
      ]
    },
    "scroll-step": 1
  },
  "network": {
    "interface": "eno1",
    "format": "{ifname}",
    "format-wifi": "<span color='#b4befe'>ΎΘτ </span>{essid}",
    "format-ethernet": "{ipaddr}/{cidr} ΎηΨ",
    "format-disconnected": "<span color='#b4befe'>≤░Ψς </span>No Network",
    "tooltip": false
  }
}
